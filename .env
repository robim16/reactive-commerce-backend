

# ── Infraestructura compartida ────────────────────────────────────────────────
API_GATEWAY_PORT=8089
SPRING_CLOUD_CONFIG_URI=http://localhost:8888
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://localhost:8761/eureka
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PASSWORD=rcredis

POSTGRES_USER=rcadmin
POSTGRES_PASSWORD=rcpassword
POSTGRES_DB=reactive_commerce

# ── PostgreSQL (auth-service, product-service, order-service) ─────────────────
SPRING_R2DBC_URL=r2dbc:postgresql://localhost:5432/reactive_commerce
SPRING_R2DBC_USERNAME=rcadmin
SPRING_R2DBC_PASSWORD=rcpassword
DB_HOST=localhost

MONGO_INITDB_ROOT_USERNAME=rcadmin
MONGO_INITDB_ROOT_PASSWORD=rcpassword

# ── MongoDB (payment, review, notification, report) ───────────────────────────
# Cada servicio usa su propia base de datos dentro del mismo servidor
# SPRING_DATA_MONGODB_URI se define por servicio (ver sección por servicio abajo)

# ── JWT — *** CAMBIAR EN PROD *** ─────────────────────────────────────────────
JWT_SECRET=reactive-commerce-secret-key-at-least-256-bits-long-for-security

# ── AWS / LocalStack ──────────────────────────────────────────────────────────
# En desarrollo local usar LocalStack. En producción usar credenciales reales.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=reactive-commerce-assets
AWS_DYNAMODB_TABLE=download-tokens
AWS_SES_FROM=noreply@reactivecommerce.com
AWS_ENDPOINT=http://localhost:4566     # Dejar vacío en producción

# ── auth-service ──────────────────────────────────────────────────────────────
# (usa variables compartidas de PostgreSQL, Redis y JWT — sin adicionales)

# ── payment-service ───────────────────────────────────────────────────────────
SPRING_DATA_MONGODB_URI_PAYMENT=mongodb://rcadmin:rcpassword@localhost:27017/payment_db?authSource=admin
PAYMENT_COMMISSION_RATE=0.20
PAYMENT_GATEWAY_URL=https://api.stripe.com
PAYMENT_GATEWAY_API_KEY=test-key
SPRING_PROFILES_ACTIVE=mock-gateway

# ── download-service ──────────────────────────────────────────────────────────
DOWNLOAD_MAX_DOWNLOADS=5

# ── review-service ────────────────────────────────────────────────────────────
SPRING_DATA_MONGODB_URI_REVIEW=mongodb://rcadmin:rcpassword@localhost:27017/review_db?authSource=admin

# ── notification-service ──────────────────────────────────────────────────────
SPRING_DATA_MONGODB_URI_NOTIFICATION=mongodb://rcadmin:rcpassword@localhost:27017/notification_db?authSource=admin
AWS_SES_FROM=noreply@reactivecommerce.com
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/notifications

# ── report-service ────────────────────────────────────────────────────────────
SPRING_DATA_MONGODB_URI_REPORT=mongodb://rcadmin:rcpassword@localhost:27017/report_db?authSource=admin
AWS_LAMBDA_REPORT_FUNCTION=report-generator

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8089
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CDN_URL=http://localhost:4566/reactive-commerce-assets  # LocalStack S3


